{
	"name": "keybindfocus",
	"displayName": "Keybindings Focus",
	"version": "0.0.1",
	"description": "Open or focus the keybindings GUI with proper focus commands",
	"publisher": "markrobbins",
	"author": "markrobbins",
	"license": "MIT",
	"engines": {
		"vscode": "^1.70.0",
		"node": ">=18"
	},
	"main": "./extension.js",
	"icon": "icon.jpg",
	"files": [
		"extension.js",
		"README.md",
		"icon.jpg",
		"LICENSE"
	],
	"devDependencies": {
		"@types/node": "^22.15.3",
		"@types/vscode": "^1.70.0",
		"@vscode/vsce": "^3.6.2"
	},
	"scripts": {
		"package": "vsce package"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/markchristianrobbins/markrobbins.git"
	},
	"activationEvents": [
		"onCommand:keybindingsFocus.open",
		"onCommand:keybindingsFocus.openSearch",
		"onCommand:keybindingsFocus.openList"
	],
	"contributes": {
		"commands": [
			{
				"command": "keybindingsFocus.open",
				"title": "Keybindings: Open or Focus"
			},
			{
				"command": "keybindingsFocus.openSearch",
				"title": "Keybindings: Open and Focus Search"
			},
			{
				"command": "keybindingsFocus.openList",
				"title": "Keybindings: Open and Focus List"
			}
		]
	}
}